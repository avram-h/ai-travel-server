.preview-label{font-size:20rpx;color:#999;margin-top:4rpx;display:block;}

.footer-links {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 28rpx 32rpx;
}

.footer-link {
  font-size: 24rpx;
  color: #999;
  padding: 0;
  font-size: 24rpx;
  color: #999;
  padding: 8rpx 24rpx;
}
.footer-link:active {
  color: #1a73e8;
}

.footer-contact {
  margin-right: 72rpx;
  background: none !important;
  border: none !important;
  padding: 0 !important;
  line-height: inherit !important;
  font-size: 24rpx !important;
  color: #999 !important;
  margin: 0 !important;
}
.footer-contact::after {
  border: none !important;
}
.footer-contact:active {
  color: #1a73e8 !important;
}


.wave-loader{position:relative;width:120rpx;height:120rpx;margin:20rpx auto 0;}
.wave-ripple{position:absolute;top:50%;left:50%;border-radius:50%;border:3rpx solid #6366f1;animation:waveRipple 2s ease-out infinite;transform:translate(-50%,-50%);}
.w1{width:40rpx;height:40rpx;animation-delay:0s;}
.w2{width:40rpx;height:40rpx;animation-delay:0.6s;}
.w3{width:40rpx;height:40rpx;animation-delay:1.2s;}
@keyframes waveRipple{0%{width:40rpx;height:40rpx;opacity:0.8;border-width:3rpx}100%{width:120rpx;height:120rpx;opacity:0;border-width:1rpx}}
.wave-core{position:absolute;top:50%;left:50%;width:40rpx;height:40rpx;transform:translate(-50%,-50%);display:flex;align-items:center;justify-content:center;}
.wave-icon{font-size:32rpx;animation:wavePulse 1.5s ease-in-out infinite;}
@keyframes wavePulse{0%,100%{transform:scale(1)}50%{transform:scale(1.15)}}
.wave-text{display:block;text-align:center;font-size:26rpx;color:#6366f1;margin-top:16rpx;}

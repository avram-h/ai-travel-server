  <div class="topbar-inner">
    <div class="logo" onclick="goHome()">
      ✈️ AI妙游
    </div>
    <div class="topbar-actions">
      <button class="topbar-link" onclick="openPrivacy()">隐私政策</button>
      <button class="topbar-link" onclick="openContact()">联系客服</button>
    </div>
  </div>
</header>

<!-- ========== 首页 ========== -->
<div id="homePage">
  <!-- Hero -->
  <section class="hero">
    <canvas id="heroCanvas"></canvas>
    <div class="radar-ring" style="top:70%;left:50%"></div>
    <div class="radar-ring" style="top:70%;left:50%"></div>
    <div class="radar-ring" style="top:70%;left:50%"></div>

    <div class="hero-badge">
      <span class="badge-dot"></span>
      AI DRIVEN · REAL DATA · INSTANT GENERATION
    </div>
    <h1>你的私人<span class="gradient">AI旅行规划师</span></h1>
    <p class="hero-sub">输入目的地和预算，秒级生成包含景点、酒店、美食、天气、交通、境外安全的完整旅行攻略</p>

    <div class="hero-search">
      <div class="search-card">
        <div class="search-grid">
          <div class="search-field">
            <label>🎯 目的地</label>
            <input type="text" id="destination" placeholder="输入目的地... 如：北京、东京、巴黎" autocomplete="off">
            <div class="quick-picks" id="destQuick"></div>
          </div>
          <div class="search-field">
            <label>📅 出行天数</label>
            <select id="days">
              <option value="1">1天</option><option value="2">2天</option>
              <option value="3" selected>3天</option><option value="4">4天</option>
              <option value="5">5天</option><option value="6">6天</option><option value="7">7天</option>
            </select>
          </div>
          <div class="search-field">
            <label>💰 每日预算</label>
            <select id="budget" onchange="updateBudgetPreview()">
              <option value="500">¥500 穷游</option><option value="1000" selected>¥1,000 经济</option>
              <option value="2000">¥2,000 舒适</option><option value="3500">¥3,500 品质</option>
              <option value="5000">¥5,000 奢华</option>
            </select>
          </div>
          <div class="search-field">
            <label>&nbsp;</label>
            <button class="btn-generate" onclick="generate()">🚀 生成攻略</button>
          </div>
        </div>
        <div class="budget-preview" id="budgetPreview"></div>
      </div>
    </div>
  </section>

  <!-- 统计 -->
  <div class="stats-bar">
    <div class="stat-item"><span class="stat-num" id="countCountries">50+</span><span class="stat-label">覆盖国家</span></div>
    <div class="stat-item"><span class="stat-num">200+</span><span class="stat-label">热门城市</span></div>
    <div class="stat-item"><span class="stat-num">99.7%</span><span class="stat-label">数据准确率</span></div>
    <div class="stat-item"><span class="stat-num">&lt;3s</span><span class="stat-label">生成速度</span></div>
  </div>

  <!-- 功能特色 -->
  <section class="features-section">
    <div class="container">
      <h2 class="section-title">为什么选择 AI妙游？</h2>
      <p class="section-sub">接入高德地图、Pexels、wttr.in 等多平台官方API，确保每一条数据真实可靠</p>
      <div class="features-grid">
        <div class="feature-card">
          <span class="feature-icon">🗺️</span>
          <h3>智能路线规划</h3>
          <p>基于高德地图POI数据，自动规划最优景点游览顺序与交通方式</p>
        </div>
        <div class="feature-card">
          <span class="feature-icon">🌤️</span>
          <h3>实时天气预报</h3>
          <p>对接气象平台获取真实天气数据，出行穿搭有据可依</p>
        </div>
        <div class="feature-card">
          <span class="feature-icon">🏨</span>
          <h3>酒店智能推荐</h3>
          <p>根据预算筛选高评分酒店，价格信息实时准确</p>
        </div>
        <div class="feature-card">
          <span class="feature-icon">🍜</span>
          <h3>地道美食发现</h3>
          <p>挖掘当地高口碑餐厅，支持一键导航直达</p>
        </div>
        <div class="feature-card">
          <span class="feature-icon">🛡️</span>
          <h3>境外安全保障</h3>
          <p>大使馆电话、紧急求助、文化习俗提醒一应俱全</p>
        </div>
        <div class="feature-card">
          <span class="feature-icon">🚗</span>
          <h3>交通比价推荐</h3>
          <p>机票、火车票、自驾多种方式对比，选最优出行方案</p>
        </div>
        <div class="feature-card">
          <span class="feature-icon">📸</span>
          <h3>实景高清图片</h3>
          <p>Pexels正版高清图库，提前感受目的地风光</p>
        </div>
        <div class="feature-card">
          <span class="feature-icon">💰</span>
          <h3>预算精细划分</h3>
          <p>交通/住宿/餐饮/门票/购物自动分配，掌控每一笔开销</p>
        </div>
      </div>
    </div>
  </section>
</div>

<!-- ========== 结果页 ========== -->
<div id="resultPage">
  <div class="result-hero">
    <div class="result-hero-inner">
      <div class="result-title">
        <h2 id="resultDest">---</h2>
        <div class="meta"><span id="resultMeta">---</span></div>
      </div>
      <button class="btn-back" onclick="goHome()">← 返回首页</button>
    </div>
    <div class="result-budget-bar" id="resultBudget"></div>
  </div>

  <nav class="tab-nav" id="tabNav">
    <button class="tab-btn active" onclick="scrollToSec('attrs', this)">🏛️ 必去景点</button>
    <button class="tab-btn" onclick="scrollToSec('spots', this)">📸 网红打卡</button>
    <button class="tab-btn" onclick="scrollToSec('hotels', this)">🏨 住宿推荐</button>
    <button class="tab-btn" onclick="scrollToSec('foods', this)">🍜 美食推荐</button>
    <button class="tab-btn" onclick="scrollToSec('weather', this)">🌤️ 天气预报</button>
    <button class="tab-btn" onclick="scrollToSec('transport', this)">🚗 交通出行</button>
    <button class="tab-btn" id="tabSafety" style="display:none" onclick="scrollToSec('safety', this)">🛡️ 境外安全</button>
  </nav>

  <div class="result-body" id="resultContent"></div>

  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-left">© 2026 AI妙游 · 智能旅行攻略生成器</div>
      <div class="footer-right">
        <button class="footer-link" onclick="openPrivacy()">隐私政策</button>
        <button class="footer-link" onclick="openContact()">联系客服</button>
      </div>
    </div>
  </footer>
</div>

<!-- ========== 加载遮罩 ========== -->
<div class="loading-overlay" id="loadingOverlay">
  <div class="cyber-loader">
    <div class="cyber-ring"></div>
    <div class="cyber-ring"></div>
    <div class="cyber-ring"></div>
    <div class="cyber-center">⚡</div>
  </div>
  <div class="loading-text" id="loadingText">数据采集中...</div>
  <div class="loading-sub" id="loadingSub"></div>
</div>

<!-- ========== Modals ========== -->
<div class="modal-overlay" id="hotelModal">
  <div class="modal-content">
    <h3 id="hotelName">🏨 酒店详情</h3>
    <div id="hotelBody"></div>
    <button class="modal-close" onclick="closeHotel()">关闭</button>
  </div>
</div>
<div class="modal-overlay" id="privacyModal">
  <div class="modal-content">
    <h3>🔒 隐私政策</h3>
    <p style="font-size:14px;color:rgba(255,255,255,0.55);line-height:1.8">
      AI妙游是一款旅游攻略生成工具，我们重视您的隐私。<br><br>
      1. 我们仅收集您输入的目的地、预算、天数等信息用于生成旅行攻略。<br>
      2. 我们不会存储您的个人信息，所有数据仅在生成过程中使用。<br>
      3. 我们使用第三方API（高德地图、Pexels、wttr.in等）获取真实数据。<br>
      4. 如有疑问请联系：kf@aimiaoyou.cn
    </p>
    <button class="modal-close" onclick="closePrivacy()">关闭</button>
  </div>
</div>

<script>
// ==================== 粒子数据流 ====================
const canvas = document.getElementById('heroCanvas');
const ctx = canvas.getContext('2d');
let particles = [];
let mouseX = -1000, mouseY = -1000;

function resizeCanvas() {
  const hero = canvas.parentElement;
  canvas.width = hero.offsetWidth;
  canvas.height = hero.offsetHeight;
}

class Particle {
  constructor() {
    this.reset();
    this.y = Math.random() * canvas.height;
  }
  reset() {
    this.x = Math.random() * canvas.width;
    this.y = -10;
    this.size = Math.random() * 2 + 0.5;
    this.speed = Math.random() * 1.2 + 0.3;
    this.opacity = Math.random() * 0.5 + 0.2;
    this.hue = Math.random() > 0.7 ? 260 : 195;
  }
  update() {
    this.y += this.speed;
    if (this.y > canvas.height + 10) this.reset();
    // 鼠标吸引
    const dx = mouseX - this.x;
    const dy = mouseY - this.y;
    const dist = Math.sqrt(dx*dx + dy*dy);
    if (dist < 150) {
      this.x += dx * 0.005;
      this.y += dy * 0.005;
    }
  }
  draw(ctx) {
    ctx.beginPath();
    ctx.arc(this.x, this.y, this.size, 0, Math.PI*2);
    ctx.fillStyle = `hsla(${this.hue}, 80%, 65%, ${this.opacity})`;
    ctx.fill();
    // 发光
    ctx.beginPath();
    ctx.arc(this.x, this.y, this.size*2.5, 0, Math.PI*2);
    ctx.fillStyle = `hsla(${this.hue}, 80%, 65%, ${this.opacity*0.15})`;
    ctx.fill();
  }
}

function initParticles() {
  resizeCanvas();
  particles = [];
  const count = Math.floor((canvas.width * canvas.height) / 8000);
  for (let i = 0; i < Math.min(count, 150); i++) {
    particles.push(new Particle());
  }
}

function drawConnections(ctx) {
  for (let i = 0; i < particles.length; i++) {
    for (let j = i+1; j < particles.length; j++) {
      const dx = particles[i].x - particles[j].x;
      const dy = particles[i].y - particles[j].y;
      const dist = Math.sqrt(dx*dx + dy*dy);
      if (dist < 120) {
        ctx.beginPath();
        ctx.moveTo(particles[i].x, particles[i].y);
        ctx.lineTo(particles[j].x, particles[j].y);
        ctx.strokeStyle = `rgba(99,102,241,${0.06 * (1 - dist/120)})`;
        ctx.lineWidth = 0.5;
        ctx.stroke();
      }
    }
  }
}

function animate() {
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  particles.forEach(p => { p.update(); p.draw(ctx); });
  drawConnections(ctx);
  requestAnimationFrame(animate);
}

canvas.addEventListener('mousemove', e => {
  const rect = canvas.getBoundingClientRect();
  mouseX = e.clientX - rect.left;
  mouseY = e.clientY - rect.top;
});

window.addEventListener('resize', initParticles);
initParticles();
animate();

// ==================== 业务逻辑 ====================
let travelData = null;

function init() {
  updateBudgetPreview();
  setupDestQuick();
}

function setupDestQuick() {
  const hotDests = ['北京','上海','成都','杭州','西安','三亚','日本','泰国','巴厘岛','巴黎'];
  const wrap = document.getElementById('destQuick');
  hotDests.forEach(d => {
    const chip = document.createElement('span');
    chip.className = 'quick-chip';
    chip.textContent = d;
    chip.onclick = () => {
      document.getElementById('destination').value = d;
      document.querySelectorAll('#destQuick .quick-chip').forEach(c=>c.classList.remove('active'));
      chip.classList.add('active');
    };
    wrap.appendChild(chip);
  });
}

function updateBudgetPreview() {
  const budget = parseInt(document.getElementById('budget').value) || 1000;
  const items = [
    { val: '¥'+Math.round(budget*0.35), lbl: '交通出行' },
    { val: '¥'+Math.round(budget*0.3), lbl: '酒店住宿' },
    { val: '¥'+Math.round(budget*0.2), lbl: '餐饮美食' },
    { val: '¥'+Math.round(budget*0.1), lbl: '景点门票' },
    { val: '¥'+Math.round(budget*0.05), lbl: '购物其他' },
  ];
  document.getElementById('budgetPreview').innerHTML = items.map(i=>`<div class="budget-item"><span class="val">${i.val}</span><span class="lbl">${i.lbl}</span></div>`).join('');
}

async function generate() {
  const destination = document.getElementById('destination').value.trim();
  const days = parseInt(document.getElementById('days').value);
  const budget = parseInt(document.getElementById('budget').value);
  if (!destination) return alert('请输入目的地');

  const overlay = document.getElementById('loadingOverlay');
  const text = document.getElementById('loadingText');
  const sub = document.getElementById('loadingSub');
  overlay.classList.add('show');

  const phases = [
    '正在分析目的地信息...',
    '获取景点实时数据...',
    '查询酒店信息...',
    '搜索美食推荐...',
    '获取天气预报...',
    '分析交通方案...',
    '生成安全提示...',
    '整合旅行攻略...'
  ];
  let pi = 0;
  const phaseTimer = setInterval(() => {
    if (pi < phases.length) { text.textContent = phases[pi]; sub.textContent = `Step ${pi+1}/${phases.length}`; pi++; }
  }, 700);

  try {
    const res = await fetch('/api/travel/guide', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ destination, days, budget })
    });
    const json = await res.json();
    clearInterval(phaseTimer);
    overlay.classList.remove('show');

    if (json.code !== 0) return alert('生成失败：' + (json.message||'未知错误'));
    travelData = json.data;
    renderResult();
    document.getElementById('homePage').style.display = 'none';
    document.getElementById('resultPage').classList.add('show');
    window.scrollTo(0, 0);
  } catch(e) {
    clearInterval(phaseTimer);
    overlay.classList.remove('show');
    alert('网络错误，请重试');
  }
}

function renderResult() {
  const d = travelData;
  document.getElementById('resultDest').textContent = '✈️ ' + d.destination + ' 旅行攻略';
  document.getElementById('resultMeta').innerHTML = `<span>📅 ${d.days}天</span><span>💰 每日¥${d.budget}</span><span>${d.budgetLevel?.icon||''} ${d.budgetLevel?.label||''}游</span>`;

  const b = parseInt(d.budget)||1000;
  document.getElementById('resultBudget').innerHTML = [
    {val:'¥'+Math.round(b*d.days*0.35),lbl:'交通'},
    {val:'¥'+Math.round(b*d.days*0.3),lbl:'住宿'},
    {val:'¥'+Math.round(b*d.days*0.2),lbl:'餐饮'},
    {val:'¥'+Math.round(b*d.days*0.1),lbl:'门票'},
    {val:'¥'+Math.round(b*d.days*0.05),lbl:'购物'},
  ].map(i=>`<div class="result-budget-item"><span class="val">${i.val}</span><span class="lbl">${i.lbl}</span></div>`).join('');

  document.getElementById('tabSafety').style.display = d.isOverseas ? '' : 'none';

  let html = '';

  // 景点
  html += `<div class="section-block" id="sec-attrs"><div class="sec-title">🏛️ 必去景点 <span class="source-tag">${d.isOverseas?'AI推荐':'高德POI'}</span><span class="sec-count">${d.attractions.length}个</span></div><div class="attraction-grid">`;
  d.attractions.forEach(a => {
    html += `<div class="attr-card"><div class="img-wrap"><img src="${a.image||''}" loading="lazy" onerror="this.style.display='none'"><div class="img-badges"><span class="img-badge">⭐ ${a.rating||'--'}</span></div><div class="img-actions"><button class="img-action-btn" onclick="event.stopPropagation();previewImg('${a.image||''}')" title="查看大图">🔍</button><button class="img-action-btn" onclick="event.stopPropagation();navTo('${a.name||''}','${d.destination}')" title="导航">📍</button></div></div><div class="body"><div class="name">${a.name||''}</div><div class="desc">${a.desc||''}</div></div></div>`;
  });
  html += `</div></div>`;

  // 网红打卡
  if (d.instagramSpots && d.instagramSpots.length) {
    html += `<div class="section-block" id="sec-spots"><div class="sec-title">📸 网红打卡点 <span class="source-tag">${d.isOverseas?'AI推荐':'高德POI'}</span><span class="sec-count">${d.instagramSpots.length}个</span></div><div class="attraction-grid">`;
    d.instagramSpots.forEach(s => {
      html += `<div class="attr-card"><div class="img-wrap"><img src="${s.image||''}" loading="lazy" onerror="this.style.display='none'"><div class="img-badges"><span class="img-badge">${s.type||''}</span></div><div class="img-actions"><button class="img-action-btn" onclick="event.stopPropagation();previewImg('${s.image||''}')" title="查看大图">🔍</button><button class="img-action-btn" onclick="event.stopPropagation();navTo('${s.name||''}','${d.destination}')" title="导航">📍</button></div></div><div class="body"><div class="name">${s.name||''}</div><div class="desc">${s.desc||''}</div></div></div>`;
    });
    html += `</div></div>`;
  }

  // 天气
  if (d.weather && d.weather.length) {
    html += `<div class="section-block" id="sec-weather"><div class="sec-title">🌤️ 天气预报 <span class="source-tag">wttr.in</span><span class="sec-count">${d.weather.length}天</span></div><div class="weather-grid">`;
    d.weather.forEach(w => {
      html += `<div class="weather-card"><div class="date">${w.date} ${w.weekday||''}</div><div class="condition">${w.condition?.split(' ')[0]||'☀️'}</div><div class="temps"><span class="t-l">${w.low}°</span><span class="t-h">${w.high}°</span></div><div class="detail">💧${w.humidity||'--'} 🌬️${w.wind||'--'}</div><div class="advice">${w.advice||''}</div></div>`;
    });
    html += `</div></div>`;
  }

  // 交通
  if (d.transport && d.transport.length) {
    html += `<div class="section-block" id="sec-transport"><div class="sec-title">🚗 交通出行 <span class="source-tag">AI推荐</span><span class="sec-count">${d.transport.length}种方案</span></div><div class="transport-section"><div class="transport-grid">`;
    d.transport.forEach(t => {
      html += `<div class="transport-card"><div class="type">${t.type||''}</div><div class="route">${t.route||''}</div><div class="info">${t.duration||''} · ${t.departure||''}</div><div class="price-big">¥${t.price||'--'}</div><button class="btn-book" onclick="bookTransport('${t.type||''}','${d.destination}')">🔗 去购票</button></div>`;
    });
    html += `</div></div></div>`;
  }

  // 酒店
  html += `<div class="section-block" id="sec-hotels"><div class="sec-title">🏨 住宿推荐 <span class="source-tag">${d.isOverseas?'AI推荐':'高德POI'}</span><span class="sec-count">${d.hotels.length}家</span></div><div class="hotel-grid">`;
  d.hotels.forEach((h,i) => {
    html += `<div class="hotel-card" onclick="openHotel(${i})"><div class="img-wrap"><img src="${h.image||''}" loading="lazy" onerror="this.style.display='none'"></div><div class="body"><div class="name">${h.name}</div><div class="rating">⭐ ${h.rating||'--'} ${h.star||''}</div><div class="desc">${h.desc||''}</div><div class="price">💰 ¥${h.price}起</div><div class="cta">点击查看详情 →</div></div></div>`;
  });
  html += `</div></div>`;

  // 美食
  html += `<div class="section-block" id="sec-foods"><div class="sec-title">🍜 美食推荐 <span class="source-tag">${d.isOverseas?'AI推荐':'高德POI'}</span><span class="sec-count">${d.foods.length}家</span></div><div class="food-grid">`;
  d.foods.forEach(f => {
    let bc = 'high';
    if (f.budgetMatch && f.budgetMatch.includes('友好')) bc = 'good';
    else if (f.budgetMatch && f.budgetMatch.includes('适中')) bc = 'mid';
    html += `<div class="food-card"><div class="header"><span class="name">${f.name}</span><span class="score">⭐ ${f.score||'--'}</span></div><div class="desc">${f.desc||''}</div><div class="meta"><span class="price">💰 人均约 ¥${f.price}</span><span class="food-badge ${bc}">${f.budgetMatch||''}</span></div>`;
    if (f.tags && f.tags.length) html += `<div class="food-tags">${f.tags.map(t=>`<span class="food-tag">${t}</span>`).join('')}</div>`;
    html += `<button class="btn-nav" onclick="navTo('${f.name}','${d.destination}')">📍 带我去这里</button></div>`;
  });
  html += `</div></div>`;

  // 境外安全
  if (d.isOverseas && d.safetyInfo) {
    const s = d.safetyInfo;
    html += `<div class="section-block" id="sec-safety"><div class="sec-title">🛡️ 境外安全提醒 <span class="safety-badge" style="display:inline-block;margin-left:8px;vertical-align:middle">重要</span></div>`;
    html += `<div class="safety-grid"><div class="safety-card"><div class="title">🛡️ ${s.country||d.destination} <span class="safety-badge">安全评级：${s.level||'注意'}</span></div><div class="safety-contact-item"><span class="lbl">📞 大使馆电话</span><span class="val">${s.embassyPhone||'--'}</span></div><div class="safety-contact-item"><span class="lbl">🚨 紧急求助</span><span class="val">${s.emergencyPhone||'--'}</span></div></div>`;
    if (s.alerts || s.tips) {
      html += `<div class="safety-card">`;
      if (s.alerts && s.alerts.length) html += `<div class="safety-list"><span class="lbl">⚠️ 安全提醒</span>${s.alerts.map(a=>`<div class="item">• ${a}</div>`).join('')}</div>`;
      if (s.tips && s.tips.length) html += `<div class="safety-list"><span class="lbl" style="color:#10b981">💡 出行建议</span>${s.tips.map(t=>`<div class="item">• ${t}</div>`).join('')}</div>`;
      html += `</div>`;
    }
    html += `</div></div>`;
  }

  document.getElementById('resultContent').innerHTML = html;
}

function scrollToSec(id, el) {
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  el.classList.add('active');
  const sec = document.getElementById('sec-'+id);
  if (sec) sec.scrollIntoView({behavior:'smooth', block:'start'});
}

function goHome() {
  document.getElementById('homePage').style.display = '';
  document.getElementById('resultPage').classList.remove('show');
  window.scrollTo(0, 0);
}

function previewImg(src) { if (src) window.open(src, '_blank'); }

function navTo(name, dest) {
  const query = encodeURIComponent(name + ' ' + dest);
  window.open('https://uri.amap.com/search?keyword=' + query, '_blank');
}

function bookTransport(type, dest) {
  if (type.includes('飞机') || type.includes('机票')) window.open('https://flights.ctrip.com/', '_blank');
  else if (type.includes('火车') || type.includes('高铁')) window.open('https://www.12306.cn/', '_blank');
  else { const q = encodeURIComponent(dest + ' 租车'); window.open('https://uri.amap.com/search?keyword=' + q, '_blank'); }
}

function openHotel(i) {
  if (!travelData) return;
  const h = travelData.hotels[i];
  if (!h) return;
  document.getElementById('hotelName').textContent = '🏨 ' + h.name;
  document.getElementById('hotelBody').innerHTML = `
    <div class="row"><strong>⭐ 评分：</strong>${h.rating||'--'} ${h.star||''}</div>
    <div class="row"><strong>💰 价格：</strong>¥${h.price}起</div>
    <div class="row"><strong>📝 简介：</strong>${h.desc||'暂无介绍'}</div>
    <div class="row"><strong>📍 地址：</strong>${h.address||'暂无地址'}</div>
    <div class="row"><strong>📞 电话：</strong>${h.tel||'暂无电话'}</div>
    <button class="btn-nav" style="margin-top:12px" onclick="navTo('${h.name}','${travelData.destination}')">📍 导航到酒店</button>
  `;
  document.getElementById('hotelModal').classList.add('show');
}

function closeHotel() { document.getElementById('hotelModal').classList.remove('show'); }
function openPrivacy() { document.getElementById('privacyModal').classList.add('show'); }
function closePrivacy() { document.getElementById('privacyModal').classList.remove('show'); }
function openContact() { alert('📧 客服邮箱：kf@aimiaoyou.cn\n📱 微信公众号：AI妙游'); }

document.getElementById('hotelModal').addEventListener('click', function(e) { if (e.target === this) closeHotel(); });
document.getElementById('privacyModal').addEventListener('click', function(e) { if (e.target === this) closePrivacy(); });

init();
</script>
</body>
</html>

.page {
  padding: 32rpx 28rpx 60rpx;
  background: #f5f7fa;
  min-height: 100vh;
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
}
.title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  text-align: center;
  margin-bottom: 8rpx;
}
.date {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 40rpx;
}
.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}
.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a73e8;
  margin-bottom: 12rpx;
}
.section-text {
  display: block;
  font-size: 26rpx;
  color: #555;
  margin-bottom: 8rpx;
}
.footer {
  text-align: center;
  color: #bbb;
  font-size: 22rpx;
  margin-top: 40rpx;
}

.contact-btn {
  margin-top: 16rpx;
  background: #1a73e8;
  color: #fff;
  font-size: 28rpx;
  border-radius: 12rpx;
  padding: 16rpx 0;
  text-align: center;
  border: none;
  width: 100%;
}
.contact-btn::after {
  border: none;
}

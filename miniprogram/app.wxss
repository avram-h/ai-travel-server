/** app.wxss - 全局样式 **/
@import './styles/variables.wxss';

view, text, image, scroll-view, swiper, navigator {
  box-sizing: border-box;
}

page {
  background-color: var(--bg-primary, #f5f7fa);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  color: var(--text-primary, #2c3e50);
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 20rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-title .icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 12rpx;
}

.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 22rpx;
  font-weight: 500;
  margin: 4rpx 8rpx 4rpx 0;
}

.tag-primary { background: #e8f0fe; color: #1a73e8; }
.tag-success { background: #e6f7ed; color: #0d9f6e; }
.tag-warning { background: #fef3e8; color: #e3741a; }
.tag-danger { background: #fde8e8; color: #e31a1a; }

.loading-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(255,255,255,0.85);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #e8ecf1;
  border-top-color: #1a73e8;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #666;
}

.fade-in {
  animation: fadeIn 0.5s ease-out both;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

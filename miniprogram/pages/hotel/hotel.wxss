.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 照片轮播 */
.photo-swiper {
  width: 100%;
  height: 500rpx;
}
.swiper-image {
  width: 100%;
  height: 100%;
}
.photo-placeholder {
  width: 100%;
  height: 360rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.placeholder-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}
.placeholder-text {
  color: rgba(255,255,255,0.7);
  font-size: 28rpx;
}

/* 信息区域 */
.info-section {
  margin: -30rpx 24rpx 0;
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 30rpx;
  position: relative;
  z-index: 1;
}

.hotel-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.hotel-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
  flex: 1;
  margin-right: 16rpx;
}
.star-badge {
  background: linear-gradient(135deg, #f0a030, #e07020);
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 600;
  white-space: nowrap;
}

.rating-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 8rpx;
}
.rating-text {
  font-size: 26rpx;
  color: #666;
}
.price-text {
  font-size: 28rpx;
  color: #e07020;
  font-weight: 600;
}

.divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 24rpx 0;
}

.section-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
  display: block;
}
.desc-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.tag-item {
  background: #e8f0fe;
  color: #1a73e8;
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.info-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}
.info-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}
.info-text {
  font-size: 26rpx;
  color: #444;
  flex: 1;
}
.tel-row {
  border-top: 1rpx solid #f0f0f0;
  margin-top: 8rpx;
  padding-top: 20rpx;
}
.tel-text {
  color: #1a73e8;
}
.call-btn {
  background: #e8f0fe;
  color: #1a73e8;
  font-size: 22rpx;
  padding: 6rpx 24rpx;
  border-radius: 30rpx;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 24rpx 40rpx;
  background: #fff;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06);
}
.bottom-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
}
.nav-btn {
  background: linear-gradient(135deg, #43e97b, #38f9d7);
  color: #fff;
}
.call-btn-primary {
  background: linear-gradient(135deg, #1a73e8, #0d47a1);
  color: #fff;
}

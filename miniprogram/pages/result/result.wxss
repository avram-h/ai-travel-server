/* === 基础重置 === */
.page { background: #f5f7fa; min-height: 100vh; }
view, text, image, button { box-sizing: border-box; margin: 0; padding: 0; }

/* === 头部 === */
.result-header { position: relative; overflow: hidden; padding: 40rpx 28rpx 50rpx; background: linear-gradient(135deg, #1a73e8 0%, #0d47a1 50%, #6a1b9a 100%); z-index: 1; }
.header-dots { position: absolute; top: 0; left: 0; right: 0; bottom: 0; pointer-events: none; z-index: 0; }
.hd { position: absolute; border-radius: 50%; animation: hdFlow 8s linear infinite; will-change: transform; pointer-events: none; }
.hd1 { width: 3rpx; height: 3rpx; background: rgba(255,255,255,0.3); left: 11%; top: 40%; animation-delay: 5.2s; }
.hd3 { width: 5rpx; height: 5rpx; background: rgba(255,255,255,0.26); left: 10%; top: 55%; animation-delay: 4s; animation-duration: 9s; }
.hd6 { width: 4rpx; height: 4rpx; background: rgba(255,255,255,0.28); left: 64%; top: 60%; animation-delay: 2.1s; animation-duration: 8s; }
.hd9 { width: 3rpx; height: 3rpx; background: rgba(255,255,255,0.22); left: 3%; top: 57%; animation-delay: 2.7s; animation-duration: 7s; }
.hd12 { width: 3rpx; height: 3rpx; background: rgba(255,255,255,0.29); left: 93%; top: 91%; animation-delay: 1.3s; animation-duration: 6s; }
.hd15 { width: 3rpx; height: 3rpx; background: rgba(255,255,255,0.29); left: 14%; top: 42%; animation-delay: 2s; animation-duration: 8s; }
.hd18 { width: 3rpx; height: 3rpx; background: rgba(255,255,255,0.38); left: 64%; top: 66%; animation-delay: 5.7s; animation-duration: 5s; }
.hd20 { width: 5rpx; height: 5rpx; background: rgba(255,255,255,0.36); left: 20%; top: 81%; animation-delay: 1.9s; animation-duration: 6s; }
@keyframes hdFlow { 0% { transform: translateY(0) translateX(0); opacity: 0; } 10% { opacity: 0.6; } 90% { opacity: 0.4; } 100% { transform: translateY(-120rpx) translateX(8rpx); opacity: 0; } }
.header-content { position: relative; z-index: 1; }
.header-title { display: block; font-size: 40rpx; font-weight: 700; color: #fff; margin-bottom: 12rpx; }
.header-meta { display: flex; gap: 12rpx; margin-bottom: 12rpx; }
.meta-item { font-size: 22rpx; color: rgba(255,255,255,0.9); background: rgba(255,255,255,0.15); padding: 4rpx 14rpx; border-radius: 20rpx; }
.header-summary { margin-bottom: 12rpx; }
.summary-text { font-size: 26rpx; color: rgba(255,255,255,0.9); }
.header-trust { display: flex; gap: 8rpx; flex-wrap: wrap; }
.trust-badge { font-size: 20rpx; color: rgba(255,255,255,0.8); background: rgba(255,255,255,0.12); padding: 4rpx 12rpx; border-radius: 20rpx; }
.header-wave { position: absolute; bottom: 0; left: 0; right: 0; height: 30rpx; z-index: 0; }
.wave { position: absolute; bottom: 0; width: 200%; height: 30rpx; border-radius: 50%; }
.wave1 { left: -50%; background: rgba(255,255,255,0.08); }
.wave2 { left: -30%; background: rgba(255,255,255,0.05); bottom: -5rpx; }
.wave3 { left: -10%; background: rgba(255,255,255,0.03); bottom: -10rpx; }

/* === 导航 === */
.nav-tabs { white-space: nowrap; padding: 16rpx 20rpx; background: #fff; position: sticky; top: 0; z-index: 99; }
.nav-tab { display: inline-flex; align-items: center; padding: 10rpx 22rpx; border-radius: 24rpx; font-size: 24rpx; background: #f0f2f5; color: #666; margin-right: 10rpx; }
.nav-tab.active { background: linear-gradient(135deg, #1a73e8, #6366f1); color: #fff; }

/* === 通用 === */
.section-wrapper { margin-bottom: 28rpx; }
.section-header { display: flex; align-items: center; gap: 10rpx; padding: 18rpx 28rpx 12rpx; }
.section-title-icon { font-size: 32rpx; }
.section-title-text { font-size: 30rpx; font-weight: 700; color: #1a1a2e; }
.section-count { font-size: 22rpx; color: #999; margin-left: auto; }
.source-tag { font-size: 18rpx; color: #fff; background: #10b981; padding: 2rpx 10rpx; border-radius: 8rpx; }
.source-tag.live { background: linear-gradient(135deg, #10b981, #059669); }
.tag-sm { display: inline-block; font-size: 18rpx; color: #fff; background: rgba(0,0,0,0.5); padding: 3rpx 10rpx; border-radius: 6rpx; margin: 2rpx; }

/* === 交通 === */
.transport-card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin: 0 24rpx; }
.transport-route { display: flex; align-items: center; gap: 12rpx; margin-bottom: 20rpx; padding-bottom: 16rpx; border-bottom: 1rpx solid #f0f0f0; }
.tr-from,.tr-to { font-size: 30rpx; font-weight: 700; color: #1a1a2e; }
.tr-arrow { font-size: 28rpx; color: #6366f1; font-weight: 700; }
.tr-info { font-size: 22rpx; color: #999; margin-left: auto; }
.transport-item { display: flex; align-items: center; justify-content: space-between; padding: 18rpx 16rpx; border-radius: 14rpx; margin-bottom: 10rpx; background: #f8f9fc; }
.transport-item.best { background: linear-gradient(135deg, #eef2ff, #e0e7ff); border: 1rpx solid #c7d2fe; }
.ti-left { display: flex; align-items: center; gap: 14rpx; }
.ti-icon { font-size: 36rpx; }
.ti-name { font-size: 26rpx; font-weight: 600; color: #333; display: block; }
.ti-note { font-size: 20rpx; color: #999; display: block; margin-top: 2rpx; }
.ti-mid { text-align: right; }
.ti-price { font-size: 30rpx; font-weight: 700; color: #1a73e8; display: block; }
.best .ti-price { color: #10b981; }
.ti-time { font-size: 20rpx; color: #999; display: block; }
.ti-right { display: flex; align-items: center; margin-left: 12rpx; }
.ti-buy-btn { font-size: 22rpx; color: #fff; background: linear-gradient(135deg, #6366f1, #4f46e5); border: none; border-radius: 20rpx; padding: 8rpx 22rpx; line-height: 1.4; font-weight: 500; }
.ti-buy-btn.nav-btn { background: linear-gradient(135deg, #10b981, #059669); }

/* === 景点 === */
.card-scroll { white-space: nowrap; padding: 0 24rpx 12rpx; }
.card-scroll-inner { display: inline-flex; gap: 16rpx; padding-bottom: 8rpx; }
.attraction-card { width: 300rpx; background: #fff; border-radius: 16rpx; overflow: hidden; flex-shrink: 0; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); position: relative; display: inline-block; white-space: normal; vertical-align: top; }
.attraction-image { width: 100%; height: 200rpx; display: block; background: #d0d5dd; }
.img-nav-btn { position: absolute; top: 12rpx; right: 12rpx; z-index: 2; width: 48rpx; height: 48rpx; background: rgba(0,0,0,0.4); border-radius: 50%; display: flex; align-items: center; justify-content: center; }
.img-nav-icon { font-size: 24rpx; color: #fff; }
.attraction-overlay { position: absolute; top: 148rpx; left: 0; right: 0; padding: 8rpx 12rpx; z-index: 1; }
.attraction-tags { display: flex; gap: 4rpx; flex-wrap: wrap; }
.attraction-info { padding: 14rpx 16rpx; }
.attraction-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6rpx; }
.attraction-name { font-size: 28rpx; font-weight: 600; color: #1a1a2e; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 180rpx; }
.attraction-rating { font-size: 22rpx; color: #f59e0b; }
.attraction-desc { font-size: 22rpx; color: #666; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.5; }

/* === 网红打卡 === */
.instagram-grid { display: flex; flex-wrap: wrap; padding: 0 24rpx; gap: 16rpx; }
.instagram-card { width: calc(50% - 8rpx); background: #fff; border-radius: 16rpx; overflow: hidden; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); position: relative; }
.instagram-image { width: 100%; height: 240rpx; display: block; background: #d0d5dd; }
.instagram-info { padding: 14rpx 16rpx; }
.instagram-type { display: inline-block; font-size: 20rpx; color: #6366f1; background: #eef2ff; padding: 3rpx 12rpx; border-radius: 8rpx; margin-bottom: 8rpx; }
.instagram-name { font-size: 26rpx; font-weight: 600; color: #1a1a2e; display: block; margin-bottom: 4rpx; }
.instagram-desc { font-size: 22rpx; color: #666; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.5; }

/* === 天气 === */
.weather-overview { background: #fff; border-radius: 16rpx; padding: 24rpx; margin: 0 24rpx 16rpx; }
.weather-summary { text-align: center; }
.weather-temp-range { font-size: 38rpx; font-weight: 700; color: #1a73e8; display: block; }
.weather-advice { font-size: 24rpx; color: #666; margin-top: 8rpx; display: block; }
.weather-scroll { padding: 0 24rpx; white-space: nowrap; }
.weather-scroll-inner { display: inline-flex; gap: 16rpx; padding-bottom: 8rpx; }
.weather-card { width: 180rpx; background: #fff; border-radius: 14rpx; padding: 18rpx 14rpx; text-align: center; flex-shrink: 0; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); display: inline-block; white-space: normal; vertical-align: top; }
.weather-weekday { font-size: 26rpx; font-weight: 600; color: #333; display: block; }
.weather-date { font-size: 20rpx; color: #999; display: block; margin-bottom: 8rpx; }
.weather-condition { font-size: 30rpx; display: block; margin-bottom: 8rpx; }
.weather-temp-bar { height: 6rpx; background: #e8ecf1; border-radius: 3rpx; margin-bottom: 8rpx; position: relative; overflow: hidden; }
.temp-bar-inner { position: absolute; top: 0; height: 100%; background: linear-gradient(90deg, #60a5fa, #f59e0b); border-radius: 3rpx; }
.weather-temps { display: flex; justify-content: space-between; margin-bottom: 8rpx; }
.temp-low { font-size: 22rpx; color: #60a5fa; }
.temp-high { font-size: 22rpx; color: #f59e0b; }
.weather-detail { display: flex; justify-content: center; gap: 10rpx; margin-bottom: 8rpx; }
.weather-detail-item { font-size: 18rpx; color: #999; }
.weather-advice-text { font-size: 20rpx; color: #10b981; display: block; }

/* === 酒店 === */
.hotel-list { padding: 0 24rpx; }
.hotel-card { display: flex; padding: 16rpx; gap: 16rpx; align-items: flex-start; position: relative; background: #fff; border-radius: 16rpx; margin-bottom: 16rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.hotel-image { width: 140rpx; height: 140rpx; border-radius: 12rpx; flex-shrink: 0; display: block; background: #d0d5dd; }
.hotel-badge { position: absolute; top: 20rpx; left: 130rpx; font-size: 20rpx; background: linear-gradient(135deg, #f59e0b, #d97706); color: #fff; padding: 2rpx 10rpx; border-radius: 8rpx; z-index: 1; }
.hotel-rating-row { display: flex; align-items: center; gap: 8rpx; margin-top: 2rpx; }
.hotel-star { font-size: 20rpx; color: #f59e0b; }
.hotel-tel { font-size: 20rpx; color: #999; display: block; margin-top: 4rpx; }
.hotel-click-hint { font-size: 20rpx; color: #6366f1; margin-top: 6rpx; }

/* === 美食 === */
.food-list { padding: 0 24rpx; }
.food-card { background: #fff; border-radius: 16rpx; padding: 22rpx; margin-bottom: 16rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.food-content { flex: 1; min-width: 0; }
.food-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.food-name { font-size: 28rpx; font-weight: 600; color: #1a1a2e; }
.food-score { font-size: 24rpx; color: #f59e0b; }
.food-desc { font-size: 24rpx; color: #666; display: block; margin-bottom: 8rpx; line-height: 1.6; }
.food-meta { display: flex; align-items: center; gap: 12rpx; margin-bottom: 8rpx; flex-wrap: wrap; }
.food-price { font-size: 24rpx; color: #1a73e8; font-weight: 500; }
.food-budget { font-size: 20rpx; padding: 3rpx 12rpx; border-radius: 8rpx; }
.food-budget.friendly { background: #d1fae5; color: #065f46; }
.food-budget.moderate { background: #fef3c7; color: #92400e; }
.food-budget.premium { background: #fce7f3; color: #9d174d; }
.food-tags { display: flex; gap: 6rpx; flex-wrap: wrap; margin-bottom: 12rpx; }
.food-nav { display: flex; align-items: center; gap: 8rpx; background: #ecfdf5; padding: 14rpx 18rpx; border-radius: 12rpx; }
.food-nav-icon { font-size: 24rpx; }
.food-nav-text { font-size: 24rpx; color: #059669; font-weight: 500; }

/* === 安全 === */
.badge-warning { color: #fff; background: #f59e0b; padding: 3rpx 12rpx; border-radius: 8rpx; font-size: 20rpx; }
.safety-level { background: #fff; border-radius: 16rpx; padding: 22rpx 24rpx; margin: 0 24rpx 16rpx; }
.safety-level-header { display: flex; align-items: center; gap: 12rpx; margin-bottom: 18rpx; }
.safety-flag { font-size: 40rpx; }
.safety-country { font-size: 28rpx; font-weight: 700; display: block; color: #1a1a2e; }
.safety-level-badge { font-size: 22rpx; padding: 3rpx 12rpx; border-radius: 8rpx; display: inline-block; }
.safety-level-badge.warning { background: #fef3c7; color: #92400e; }
.safety-contacts { display: flex; gap: 16rpx; }
.contact-item { flex: 1; background: #f8f9fc; padding: 16rpx; border-radius: 12rpx; }
.contact-label { font-size: 22rpx; color: #999; display: block; margin-bottom: 6rpx; }
.contact-value { font-size: 26rpx; color: #1a73e8; font-weight: 600; }
.selectable { user-select: text; -webkit-user-select: text; }
.card-section-title { font-size: 26rpx; font-weight: 600; color: #333; display: block; margin-bottom: 14rpx; }
.local-news { background: #fff; border-radius: 16rpx; padding: 22rpx 24rpx; margin: 0 24rpx 16rpx; }
.news-item { display: flex; gap: 10rpx; margin-bottom: 12rpx; }
.news-dot { width: 8rpx; height: 8rpx; background: #6366f1; border-radius: 50%; margin-top: 10rpx; flex-shrink: 0; }
.news-title { font-size: 24rpx; color: #333; display: block; }
.news-meta { font-size: 20rpx; color: #999; display: block; margin-top: 2rpx; }
.safety-tips { background: #fff; border-radius: 16rpx; padding: 22rpx 24rpx; margin: 0 24rpx 16rpx; }
.tip-item { display: flex; gap: 8rpx; margin-bottom: 10rpx; align-items: flex-start; }
.tip-bullet { font-size: 24rpx; color: #f59e0b; flex-shrink: 0; }
.tip-bullet.tip-green { color: #10b981; }
.tip-text { font-size: 24rpx; color: #555; line-height: 1.6; }

/* === 广告 + 页脚 === */
.ad-section { padding: 0 24rpx 20rpx; }
.footer { text-align: center; padding: 30rpx 0 50rpx; }
.footer-text { font-size: 24rpx; color: #bbb; display: block; }
.footer-sub { font-size: 20rpx; color: #ccc; margin-top: 6rpx; display: block; }

/* ====== 加载骨架 ====== */
.loading-skel { padding: 24rpx 28rpx; }
.skel-block { height: 80rpx; background: #e8ecf1; border-radius: 12rpx; margin-bottom: 20rpx; animation: skelPulse 1.5s ease-in-out infinite; }
.skel-block.short { width: 60%; }
@keyframes skelPulse { 0%,100% { opacity: 0.4; } 50% { opacity: 0.7; } }

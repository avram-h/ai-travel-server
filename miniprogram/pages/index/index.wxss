.hero-content{position:relative;z-index:2;}
.hero-title{font-size:52rpx;font-weight:800;background:linear-gradient(135deg,#1a73e8,#0d47a1);-webkit-background-clip:text;-webkit-text-fill-color:transparent;display:block;}
.hero-subtitle{font-size:26rpx;color:#5f6368;margin-top:10rpx;display:block;}
.hero-badges{display:flex;justify-content:center;gap:14rpx;margin-top:18rpx;flex-wrap:wrap;}
.trust-badge-sm{font-size:20rpx;color:#1a73e8;background:rgba(26,115,232,0.1);padding:6rpx 18rpx;border-radius:20rpx;font-weight:500;}

/* === 表单 === */
.form-section{margin:0 28rpx;background:#fff;border-radius:24rpx;padding:30rpx;box-shadow:0 4rpx 24rpx rgba(0,0,0,0.06);}
.form-group{margin-bottom:24rpx;}
.form-group:last-child{margin-bottom:0;}
.form-label{font-size:24rpx;color:#444;font-weight:600;margin-bottom:10rpx;display:block;}
.input-wrapper{position:relative;display:flex;align-items:center;background:#f5f7fa;border-radius:16rpx;border:2rpx solid transparent;transition:all 0.2s;}
.input-filled{border-color:#1a73e8;background:#f0f5ff;}
.form-input{flex:1;height:88rpx;padding:0 24rpx;font-size:30rpx;background:transparent;}
.unit{font-size:24rpx;color:#999;margin-right:20rpx;}
.clear-btn{font-size:28rpx;color:#999;padding:0 20rpx;}
.form-row{display:flex;gap:20rpx;}
.half{flex:1;}
.suggestions{max-height:260rpx;overflow-y:auto;background:#fff;border-radius:12rpx;box-shadow:0 4rpx 16rpx rgba(0,0,0,0.1);margin-top:6rpx;display:none;}
.suggestions.show{display:block;}
.suggestion-item{padding:20rpx 24rpx;font-size:26rpx;border-bottom:1rpx solid #f0f0f0;}
.suggestion-icon{margin-right:10rpx;}

.quick-select{margin-top:20rpx;}
.quick-label{font-size:22rpx;color:#999;margin-bottom:10rpx;display:block;}
.quick-tags{display:flex;flex-wrap:wrap;gap:12rpx;}
.quick-tag{padding:10rpx 24rpx;border-radius:24rpx;font-size:24rpx;background:#f0f2f5;color:#666;}
.quick-tag.active{background:linear-gradient(135deg,#1a73e8,#0d47a1);color:#fff;}
.hot-destinations{margin-top:20rpx;}
.hot-tag{padding:8rpx 22rpx;border-radius:20rpx;font-size:22rpx;background:#fff3e0;color:#e65100;}

.preview-section{margin:24rpx 28rpx 0;background:#fff;border-radius:20rpx;padding:24rpx;box-shadow:0 4rpx 20rpx rgba(0,0,0,0.04);}
.preview-title{font-size:26rpx;font-weight:600;color:#333;margin-bottom:18rpx;display:block;}
.preview-grid{display:flex;}
.preview-item{flex:1;text-align:center;}
.preview-value{font-size:30rpx;font-weight:700;color:#1a73e8;display:block;}
.preview-label{font-size:20rpx;color:#999;margin-top:4rpx;display:block;}

.features-section{display:flex;flex-wrap:wrap;padding:16rpx 20rpx;margin:24rpx 28rpx 0;background:#fff;border-radius:20rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,0.04);}
.feature-item{display:flex;align-items:center;width:50%;padding:16rpx 8rpx;box-sizing:border-box;}
.feature-icon{font-size:32rpx;margin-right:10rpx;width:40rpx;text-align:center;flex-shrink:0;}
.feature-text{flex:1;min-width:0;}
.feature-title{font-size:24rpx;font-weight:600;color:#333;display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.feature-desc{font-size:20rpx;color:#999;margin-top:2rpx;display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}

.action-section{padding:32rpx 28rpx 8rpx;}
.generate-btn{width:100%;height:104rpx;border-radius:52rpx;font-size:34rpx;font-weight:700;border:none;color:#fff;background:linear-gradient(135deg,#a8c7fa,#8ab4f8);display:flex;align-items:center;justify-content:center;transition:all 0.3s;}
.generate-btn.active{background:linear-gradient(135deg,#1a73e8,#0d47a1);box-shadow:0 8rpx 32rpx rgba(26,115,232,0.3);}
.generate-btn[disabled]{background:linear-gradient(135deg,#e8eaed,#dadce0);color:#999;}

/* 加载动画 */
.loading-box{margin:0 28rpx;}
.loading-btn{display:flex;flex-direction:column;align-items:center;padding:24rpx;position:relative;width:100%;height:104rpx;border-radius:52rpx;background:linear-gradient(135deg,#1a73e8,#0d47a1);display:flex;align-items:center;justify-content:center;overflow:hidden;}
.loading-shimmer{display:none;position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.2),transparent);animation:shimmer 1.8s linear infinite;}
